{
  "name": "learnhands",
  "version": "4.1.2",
  "description": "LearnHands — Plataforma educativa de movimiento natural para Fe y Alegría Ecuador",
  "author": "Fe y Alegría Ecuador <info@feyalegria.edu.ec>",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "kill-port": "node scripts/kill-port.mjs 5173",
    "electron:dev": "node scripts/kill-port.mjs 5173 && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.feyalegria.learnhands",
    "productName": "LearnHands",
    "copyright": "Copyright © 2024 Fe y Alegría Ecuador",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/@mediapipe/tasks-vision/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "es_ES"
      ],
      "language": "3082"
    }
  }
}
